<mvc:View
    controllerName="syntax.max.ai.synKiCopilot.controller.SynKiCopilot"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:html="http://www.w3.org/1999/xhtml"
    height="100%">

    <!-- Main Container with Sidebar Overlay -->
    <HBox id="mainContainer" height="100%" width="100%" class="synCopilotMainContainer">

        <!-- ============================================ -->
        <!-- SIDEBAR PANEL (Joule-style menu)            -->
        <!-- ============================================ -->
        <VBox id="sidebarPanel" visible="false" class="synCopilotSidebar">
            <!-- Sidebar Header -->
            <HBox class="synCopilotSidebarHeader" alignItems="Center" justifyContent="SpaceBetween">
                <HBox alignItems="Center">
                    <Button
                        icon="sap-icon://menu2"
                        type="Transparent"
                        press="onCloseSidebar"
                        class="synCopilotSidebarMenuBtn" />
                    <Text text="SAP AI Chat" class="synCopilotSidebarTitle" />
                </HBox>
                <Button
                    icon="sap-icon://decline"
                    type="Transparent"
                    press="onCloseSidebar"
                    class="synCopilotSidebarCloseBtn" />
            </HBox>

            <!-- New Conversation Button -->
            <HBox class="synCopilotSidebarNewConv">
                <Button
                    text="Neues Gespr&#228;ch"
                    icon="sap-icon://add"
                    type="Transparent"
                    press="onNewConversation"
                    class="synCopilotNewConvBtn" />
            </HBox>

            <!-- History Section -->
            <VBox class="synCopilotSidebarHistorySection">
                <HBox class="synCopilotHistoryHeader" alignItems="Center" justifyContent="SpaceBetween">
                    <HBox alignItems="Center">
                        <Text text="Verlauf" class="synCopilotHistoryTitle" />
                    </HBox>
                    <Button
                        id="historyToggleBtn"
                        icon="sap-icon://navigation-down-arrow"
                        type="Transparent"
                        press="onToggleHistory"
                        class="synCopilotHistoryToggleBtn" />
                </HBox>

                <!-- History List (scrollable) -->
                <ScrollContainer
                    id="historyScrollContainer"
                    height="100%"
                    width="100%"
                    vertical="true"
                    class="synCopilotHistoryScroll">
                    <VBox id="historyList" class="synCopilotHistoryList">
                        <!-- History items will be added dynamically -->
                    </VBox>
                </ScrollContainer>
            </VBox>
        </VBox>

        <!-- Sidebar Overlay (click to close) -->
        <html:div id="sidebarOverlay" class="synCopilotSidebarOverlay" style="display:none"></html:div>

        <!-- ============================================ -->
        <!-- MAIN CHAT AREA                              -->
        <!-- ============================================ -->
        <VBox id="chatRootVBox" class="synCopilotRoot" height="100%">

            <!-- Persistent Header Bar (always visible) -->
            <HBox class="synCopilotHeader" alignItems="Center" justifyContent="SpaceBetween">
                <HBox alignItems="Center">
                    <Button
                        id="menuBtn"
                        icon="sap-icon://menu2"
                        type="Transparent"
                        press="onMenuPress"
                        class="synCopilotMenuBtn" />
                    <Text id="headerTitle" text="SAP AI Chat" class="synCopilotHeaderTitle" />
                </HBox>
                <Button
                    id="closeBtn"
                    icon="sap-icon://decline"
                    type="Transparent"
                    press="onClosePlugin"
                    class="synCopilotMenuBtn" />
            </HBox>

            <!-- ============================================ -->
            <!-- CHAT VIEW                                   -->
            <!-- ============================================ -->
            <VBox id="chatViewContainer" visible="true" class="synCopilotChatContainer">

                <!-- Purple Welcome Section -->
                <VBox id="welcomeSection" class="synCopilotWelcomeSection">

                    <!-- Sparkle Icon Area - Joule SVG -->
                    <VBox class="synCopilotSparkleArea" alignItems="Center" justifyContent="Center">
                        <html:div class="synCopilotJouleIcon">
                            <html:svg width="120" height="120" viewBox="0 0 122 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <html:path fill-rule="evenodd" clip-rule="evenodd" d="M46.6026 37C45.3357 37 44.1364 37.5715 43.3379 38.5556L24.9405 61.23C23.7324 62.7189 23.6834 64.8368 24.8211 66.3802L61.616 116.29C62.4087 117.365 63.6647 118 65 118C66.3353 118 67.5913 117.365 68.384 116.29L105.179 66.3802C106.317 64.8368 106.268 62.7189 105.06 61.23L86.6621 38.5556C85.8636 37.5715 84.6643 37 83.3974 37H46.6026ZM88.3249 63.5392C79.643 62.0748 76.8647 55.2489 75.9469 50.9797C75.8477 50.5577 75.302 50.5825 75.2276 51.0045C73.764 59.6919 66.9425 62.4719 62.6759 63.3903C62.2543 63.4896 62.2791 64.0357 62.7008 64.1101C71.3827 65.5746 74.1609 72.4004 75.0787 76.6697C75.178 77.0917 75.7237 77.0668 75.7981 76.6449C77.2616 67.9574 84.0832 65.1774 88.3497 64.259C88.7714 64.1598 88.7466 63.6137 88.3249 63.5392Z" fill="#ffffff"></html:path>
                                <html:path d="M101.542 20.3013C102.16 23.126 104.031 27.6422 109.878 28.6111C110.162 28.6604 110.179 29.0217 109.895 29.0874C107.022 29.695 102.428 31.5343 101.442 37.2822C101.392 37.5614 101.024 37.5778 100.958 37.2986C100.34 34.4739 98.4685 29.9578 92.6215 28.9888C92.3375 28.9396 92.3208 28.5783 92.6048 28.5126C95.4782 27.9049 100.072 26.0656 101.058 20.3178C101.108 20.0386 101.476 20.0222 101.542 20.3013Z" fill="#ffffff"></html:path>
                                <html:path d="M42.2811 0.302036C43.1925 4.53904 45.9515 11.3133 54.5733 12.7667C54.9921 12.8406 55.0167 13.3826 54.598 13.4811C50.361 14.3925 43.5867 17.1515 42.1333 25.7733C42.0594 26.1921 41.5174 26.2167 41.4189 25.798C40.5075 21.561 37.7485 14.7867 29.1267 13.3333C28.7079 13.2594 28.6833 12.7174 29.102 12.6189C33.339 11.7075 40.1133 8.94848 41.5667 0.326668C41.6406 -0.0921059 42.1826 -0.116738 42.2811 0.302036Z" fill="#ffffff"></html:path>
                                <html:path d="M16.7874 26.3048C17.395 29.1782 19.2344 33.7722 24.9822 34.7579C25.2614 34.808 25.2778 35.1755 24.9986 35.2423C22.174 35.8604 17.6578 37.7315 16.6889 43.5784C16.6396 43.8624 16.2783 43.8791 16.2126 43.5951C15.605 40.7218 13.7657 36.1277 8.01778 35.1421C7.7386 35.092 7.72218 34.7244 8.00136 34.6576C10.826 34.0395 15.3422 32.1685 16.3111 26.3215C16.3604 26.0375 16.7217 26.0208 16.7874 26.3048Z" fill="#ffffff"></html:path>
                            </html:svg>
                        </html:div>
                    </VBox>

                    <!-- Greeting -->
                    <VBox class="synCopilotGreeting">
                        <Text text="Hallo," class="synCopilotGreetingName" />
                        <Text text="Wie kann ich Ihnen helfen?" class="synCopilotGreetingQuestion" />
                    </VBox>

                    <!-- Hint Card -->
                    <VBox class="synCopilotHintCardWrapper" alignItems="Center">
                        <html:div class="synCopilotHintCard">
                            Sprechen Sie einfach mit mir.
                        </html:div>
                    </VBox>

                </VBox>

                <!-- Suggestion Chips + Chat Messages Area -->
                <ScrollContainer
                    id="chatScrollContainer"
                    height="100%"
                    width="100%"
                    vertical="true"
                    class="synCopilotContentScroll">
                    <VBox class="synCopilotContentArea">
                        <!-- Suggestion Chips (horizontal scrollable) -->
                        <HBox id="suggestionChips" class="synCopilotSuggestions">
                            <html:div class="synCopilotChip" data-chip="nc">NC-Meldungen</html:div>
                            <html:div class="synCopilotChip" data-chip="shift">Letzte Schicht</html:div>
                            <html:div class="synCopilotChip" data-chip="downtime">Stillst&#228;nde</html:div>
                            <html:div class="synCopilotChip" data-chip="top5">Top 5 Gr&#252;nde</html:div>
                            <html:div class="synCopilotChip" data-chip="quality">Qualit&#228;t</html:div>
                            <html:div class="synCopilotChip" data-chip="order">Auftragsstatus</html:div>
                        </HBox>
                        <!-- Chat Messages -->
                        <VBox id="chatMessages" class="synCopilotMessages">
                        </VBox>
                        <!-- Typing Indicator (hidden initially) -->
                        <HBox id="typingIndicator" visible="false" class="synCopilotMessageRow synCopilotMessageBot synCopilotTypingRow">
                            <core:HTML content="&lt;div class='synCopilotTypingBubble'&gt;&lt;div class='synCopilotSpinner'&gt;&lt;/div&gt;&lt;span class='synCopilotTypingText' id='synCopilotTypewriter'&gt;&lt;/span&gt;&lt;/div&gt;" />
                        </HBox>
                    </VBox>
                </ScrollContainer>

                <!-- Input Area -->
                <VBox class="synCopilotInputSection">
                    <HBox class="synCopilotInputRow" alignItems="Center">
                        <Input
                            id="chatInput"
                            placeholder="Frage stellen..."
                            width="100%"
                            submit="onSendMessage"
                            class="synCopilotInput" />
                        <Button
                            icon="sap-icon://paper-plane"
                            press="onSendMessage"
                            class="synCopilotSendBtn" />
                    </HBox>
                    <Text text="KI-generiert. Ergebnisse pr&#252;fen." class="synCopilotDisclaimer" />
                </VBox>

            </VBox>

        </VBox>

    </HBox>
</mvc:View>
